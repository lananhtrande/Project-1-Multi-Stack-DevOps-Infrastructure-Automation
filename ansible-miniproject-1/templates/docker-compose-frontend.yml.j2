services:
  vote:
    image: lananh03/vote:latest
    environment:
      - REDIS_HOST={{ my_redis_host }}
      - REDIS_PORT=6379
    ports:
      - 8080:80

  result:
    image: lananh03/result:latest
    environment:
      - PORT=80
      - PG_HOST={{ my_db_host }}
      - PG_PORT=5432
      - PG_USER=postgres
      - PG_PASSWORD=postgres
      - PG_DATABASE=postgres
    ports:
      - 8081:80